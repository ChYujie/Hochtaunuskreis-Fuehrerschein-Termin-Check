PORT=3000
BASE_URL=http://localhost:3000
CHECK_INTERVAL_MS=60000
NOTIFY_EVERY_CHECK=true

# Email is optional, but needed for real email alerts.
# Use SMTP port 465 for the built-in TLS sender.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="Appointment Watch <alerts@example.com>"

# Browser automation. Leave blank unless you need a custom module path.
PLAYWRIGHT_NODE_MODULES=
